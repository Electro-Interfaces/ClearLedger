# ClearLedger Server — переменные окружения
# Скопируйте в .env и настройте значения для production.
# При запуске через docker-compose из корня — .env не нужен, всё настроено.

DATABASE_URL=postgresql+asyncpg://clearledger:clearledger@localhost:5432/clearledger
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
OCR_ENABLED=true
